_categorys": "BA1", "evi_sum": [], "drug_var": {"drug_names": [], "var": {"gene_symbol": "MSH2", "gene_region": "exon12", "hgvs_p_abbr": "p.Gln629Arg", "hgvs_c": "c.1886A>G", "hgvs_p": "p.Q629R"}}, "gene_function": "MSH2基因属于抑癌基因，编码蛋白与MSH6蛋白、MSH3蛋白形成异二聚体，即MutS-α和MutS-β错配修复（MMR）复合物（PMID: 7973733, PMID: 8252616）。两种复合物都参与了对错配碱基对的识别，形成DNA-MutS复合物，之后向MMR机制的其他组件发出信号以切除异常核苷酸。"}, {"gene_symbol": "MSH6", "transcript_primary": "NM_000179.3", "hgvs_c": "c.3438+14A>T", "hgvs_p": "p.?", "hgvs_p_abbr": "p.?", "chr": "chr2", "start": "48030838", "end": "48030838", "ref": "A", "alt": "T", "gene_region": "intron5", "freq": 0.9965, "freq_case": 0.9965, "freq_ctrl": null, "freq_ss": null, "freq_sc": null, "freq_rc": null, "type": "Intronic", "tag": "PASS;Polymorphism;WBC", "igvplot": null, "depth": 852.0, "json_batch_name": "20240929_SHXW_A008971_ADXHS-tBPTMplus_v1.0.1.export2024929161647", "var_auto_result": null, "sample_id": "S24090705FD01", "order_code": "cdef4a347e3b11ef98d90242ac150002", "bio_category": "Snvindel", "var_id": "9620abf2cd73ceac07d67058b4f34d4e", "var_origin": "", "clinical_significance": "Benign", "function_classification": "-", "clinical_category": "Tier IV", "literature": "", "polymorphism": "Polymorphism", "variant_interpret_cn": "该变异在1000G、ExAC、gnomADe、gnomADg、iJGVD数据库人群等位基因频率分别为0.401（2008/5008）、0.4043（48869/120884）、0.4118（103194/250622）、0.3212（10066/31340）、0.5118（55578/108602）；ClinVar数据库报道为Benign（ID=42471，可靠度为三颗星）。基于剪接预测软件SpliceAI认为该变异不影响剪接。", "variant_interpret_en": "", "carcinogenicity_variant_interpret_cn": "该变异在1000G、ExAC、gnomADe、gnomADg、iJGVD数据库人群等位基因频率分别为0.401（2008/5008）、0.4043（48869/120884）、0.4118（103194/250622）、0.3212（10066/31340）、0.5123（39676/77442）；COSMIC数据库无记录。基于剪接预测软件SpliceAI认为该变异不影响剪接。", "carcinogenicity_variant_interpret_en": "", "carcinogenicity_evidence_categorys": "SBVS1;SBP1;SBP2", "variant_desc_cn": "该变异为内含子区突变。", "variant_desc_en": "", "evidence_categorys": "BA1;BP4;BP7", "evi_sum": [], "drug_var": {"drug_names": [], "var": {"gene_symbol": 