_path": [], "rna_sv": [], "mlpa": [], "hrd": [], "msi": [{"sample_id": "", "order_code": "cdef4a347e3b11ef98d90242ac150002", "var_id": "MSS", "msi_score": 0.0182, "img_path": "/var/www/html/report_backend/system_files/json_file/20240929_SHXW_A008971_ADXHS-tBPTMplus_v1.0.1.export2024929161647/S24090705FD01_S24090705FD01L01_AHTML3DMXY_1/S24090705FD01_S24090705FD01L01_AHTML3DMXY_1.msi.plot.png", "var_auto_result": "T", "variant_interpret_cn": "", "variant_interpret_en": "", "carcinogenicity_variant_interpret_cn": "", "carcinogenicity_variant_interpret_en": "", "variant_desc_cn": "微卫星（Microsatellite）又称简单重复序列（SSR），是指遍布于人类基因组中的短串联重复序列，一般由1-6个核苷酸组成。DNA复制时，肿瘤细胞内的微卫星由于重复单位的插入或缺失而造成的微卫星长度的变化，称为微卫星不稳定性（Microsatellite Instability, MSI）。大量研究表明，MSI是由错配修复（mismatch repair，MMR）基因突变或功能缺陷引起的（PMID: 25701956）。MSI在多种癌种中被发现，包括子宫内膜癌、结直肠癌和胃腺癌等。据报道，10%-15%的散发性结直肠癌患者存在MSI（PMID: 15528785），NCCN指南明确推荐所有结直肠癌患者均需考虑做MSI或MMR检测。临床上也已将MSI作为结直肠癌及其他实体瘤预后和制定辅助治疗方案的重要分子标志物。", "variant_desc_en": "", "evi_sum": [], "drug_var": {"drug_names": [], "var": {"biomarker_type": "MSS"}}}], "tmb": [], "pdl1": [], "knb": [], "ec_type": [{"sample_id": "", "order_code": "cdef4a347e3b11ef98d90242ac150002", "var_id": "CNL type EC", "variant_interpret_cn": "", "variant_interpret_en": "", "carcinogenicity_variant_interpret_cn": "", "carcinogenicity_variant_interpret_en": "", "variant_desc_cn": "非特异性分子谱（NSMP）子宫内膜癌的分子特征表现为体细胞突变少，体细胞拷贝数变异低；组织学特征表现大部分为低级别；与增高的BMI有关（PMID: 34996131）。", "variant_desc_en": "", "evi_sum": [{"regimen_name": "", "tumor_name_cn": "子宫内膜癌", "evidence_type": "Prognostic", "refer_agency": "NCCN", "literature": "ee04796d160d11ed994ac7f1c3325cc0,34996131", "clinical_significance": "Moderate", "regimen_refer_agency": "", "evi_adaptation_disease_cn": null, "evi_adaptation_disease_en": null, "evidence_level": "Clinical-phase III", "evi_conclusion": "A2", "evi_interpretation": "在III期临床试验研究PORTEC-3中（PMID: 32749941），共入组410例子宫内膜癌患者并被随机分配接受辅助放化疗治疗（CTRT组）及单独放疗（RT组），通过免疫组化和DNA测序的方法将所有肿瘤样本分成四种分子分型，并对患者的总生存期（overall survival，OS）和无复发生存期（recurrence-free survival，RFS）进行统计分析。结果显示，非特异性分子谱（NSMP）子宫内膜癌患者的5年无复发生存率为74%；辅助放化疗与辅助放疗相比，5年无复发生存率（79.7% vs 67.7%，P=0.246）和5年总生存率（89.3% vs 87.6%，P=0.434）差异无统计学意义。"}, {"regimen_name": "塞利尼索", "tumor_name_cn": "子宫内膜癌", "evidence_type": "Predictive", "refer_agency": "", "literature": "ee04796d160d11ed994ac7f1c3325cc0,34996131", "clinical_significance": "Sensitive", "regimen_refer_agency": "", "evi_adaptation_disease_cn": null, "evi_adaptation_disease_en": null, "evidence_level": "Clinical-phase III", "evi_conclusion": "B2", "evi_interpretation": "一项前瞻性、多中心、双盲、安慰剂对照的III期临床试验中（SIENDO, NCT03555422），263例晚期或经紫杉烷-铂类一线治疗后复发的子宫内膜癌患者随机分配（2:1），接受塞利尼索（SEL）、安慰剂（PLB）治疗。172例患者进行了子宫内膜癌分子分型，SEL治疗组107例患者中有37例NSMP（TP53野生型/MSS，35%），2例POLEmut（2%），18例MSI（17%），50例TP53 abnormal（46%）。PLB治疗组65例患者具有相似的分布（NSMP 31%，POLEmut 6%，MSI 12%，TP53 abnormal 51%）。亚组分析结果显示，TP53wt患者的PFS为SEL 13.7个月 vs PLB 3.7个月（HR 0.375，95%CI 0.210-0.670，p=0.0003），MSS/pMMR患者的PFS为SEL 6.9个月 vs PLB 5.4个月（HR 0.593，95%CI 0.388-0.905，p=0.007）。对NSMP患者（TP53wt，MSS）的分析显示，SEL与PLB的mPFS存在显著差异：NR和3.71个月（HR 0.163，95%CI 0.060-0.444，p<0.0001）。对其他3个分子类别的分析没有发现SEL和PLB之间PFS的显著差异。初步探索性亚组分析提示，在TP53wt，MSS和NSMP晚期或复发子宫内膜癌患者中，与安慰剂相比较，塞利尼索治疗能延长PFS。"}], "drug_var": {"drug_names": ["塞利尼索"], "var": {"biomarker_type": "CNL type EC"}}}], "cdx": [{"gene_symbol": "NTRK1", "tumor_group_id": "1", "tumor_name_cn": "实体瘤", "tumor_name_en": "Solid Tumor"}, {"gene_symbol": "NTRK2", "tumor_group_id": "1", "tumor_name_cn": "实体瘤", "tumor_name_en": "Solid Tumor"}, {"gene_symbol": "NTRK3", "tumor_group_id": "1", "tumor_name_cn": "实体瘤", "tumor_name_en": "Solid Tumor"}], "PGx": [{"clin_anno_cn": "与GG基因型患者相比，G/A基因型的患者使用伊立替康治疗时药物毒性中等", "clin_anno_en": null, "dbsnp": "rs4148323", "drug_name_cn": "伊立替康", "drug_name_en": "irinotecan", "evi_level": "1B", "gene_symbol": "UGT1A1", "genotype": "G/A", "impact_type_cn": "药物毒性较高", "impact_type_en": "Toxicity", "is_same_tumor": 0, "var_auto_result": null}, {"clin_anno_cn": "与GG基因型患者相比，A/A基因型的患者使用吉西他滨治疗时药物毒性较高", "clin_ann