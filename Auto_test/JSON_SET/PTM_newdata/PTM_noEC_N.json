c": "c.215C>G", "hgvs_p": "p.P72R"}}, "gene_function": "TP53基因属于抑癌基因（PMID: 30562755），编码蛋白参与细胞周期停滞和凋亡，是肿瘤中最常发生突变的基因（PMID: 10065147, PMID: 22713868）。"}], "sv": [], "cnv": [], "cnv_file_path": [], "rna_sv": [], "mlpa": [], "hrd": [], "msi": [{"sample_id": "", "order_code": "3bbf03941d6911ef8f8d0242ac170002", "var_id": "MSS", "msi_score": 0.0, "img_path": "/var/www/html/report_backend/system_files/json_file/20240425_XMHC_M019116_ADXHS-tBPTMplus_v1.0.1_20240507133628/BPTM-Lot19-Test01-Lib05-21030626F001D01_BPTM-Lot19-Test01-Lib05-21030626F001D01_AHJV2FAFX5_1/BPTM-Lot19-Test01-Lib05-21030626F001D01_BPTM-Lot19-Test01-Lib05-21030626F001D01_AHJV2FAFX5_1.msi.plot.png", "var_auto_result": "T", "variant_interpret_cn": "", "variant_interpret_en": "", "carcinogenicity_variant_interpret_cn": "", "carcinogenicity_variant_interpret_en": "", "variant_desc_cn": "微卫星（Microsatellite）又称简单重复序列（SSR），是指遍布于人类基因组中的短串联重复序列，一般由1-6个核苷酸组成。DNA复制时，肿瘤细胞内的微卫星由于重复单位的插入或缺失而造成的微卫星长度的变化，称为微卫星不稳定性（Microsatellite Instability, MSI）。大量研究表明，MSI是由错配修复（mismatch repair，MMR）基因突变或功能缺陷引起的（PMID: 25701956）。MSI在多种癌种中被发现，包括子宫内膜癌、结直肠癌和胃腺癌等。据报道，10%-15%的散发性结直肠癌患者存在MSI（PMID: 15528785），NCCN指南明确推荐所有结直肠癌患者均需考虑做MSI或MMR检测。临床上也已将MSI作为结直肠癌及其他实体瘤预后和制定辅助治疗方案的重要分子标志物。", "variant_desc_en": "", "evi_sum": [], "drug_var": {"drug_names": [], "var": {"biomarker_type": "MSS"}}}], "tmb": [], "pdl1": [], "knb": [], "ec_type": [], "cdx": [{"gene_symbol": "BRCA1", "tumor_group_id": "1", "tumor_name_cn": "卵巢癌", "tumor_name_en": "Ovarian Cancer"}, {"gene_symbol": "BRCA2", "tumor_group_id": "1", "tumor_name_cn": "卵巢癌", "tumor_name_en": "Ovarian Cancer"}], "PGx": [{"clin_anno_cn": "与 GG 基因型患者相比，A/G基因型的患者使用铂类治疗时药物毒性中等", "clin_anno_en": null, "dbsnp": "rs11615", "drug_name_cn": "铂类", "drug_name_en": "platinum", "evi_level": "3", "gene_symbol": "ERCC1", "genotype": "A/G", "impact_type_cn": "药物毒性中等", "impact_type_en": "Toxicity", "is_same_tumor": 0, "var_auto_result": null}, {"clin_anno_cn": "与CG或CC基因型患者相比，G/G基因型的患者使用卡培他滨治疗时药物毒性较低", "clin_anno_en": n