228659, PMID: 29352080）。", "carcinogenicity_variant_interpret_en": "", "carcinogenicity_evidence_categorys": "OP4;OP1;OS2;OM3", "variant_desc_cn": "该变异为错义突变，导致基因编码蛋白第286位氨基酸由脯氨酸突变为精氨酸。", "variant_desc_en": "", "evidence_categorys": "PM2_Supporting;PP3;PS3;PM1", "evi_sum": [{"regimen_name": "PD-1抑制剂", "tumor_name_cn": "实体瘤", "evidence_type": "Predictive", "refer_agency": "", "literature": "f2138d6c160d11edac9bc7f1c3325cc0,29352080,26619011,25228659,31829442", "clinical_significance": "Sensitive", "regimen_refer_agency": "", "evi_adaptation_disease_cn": null, "evi_adaptation_disease_en": null, "evidence_level": "Clinical-retrospective", "evi_conclusion": "C1", "evi_interpretation": "一项回顾性研究（DOI: 10.1200/JCO.2020.38.15_suppl.3008），分析了12947位病人的数据，有448位（3.5%）有POLE突变或者CNV，这些POLE突变中，致病性/可能致病性的占11.6%（34/293），良性/可能良性的占20.8%（61/293），意义不明确的占67.6%（198/293）。293个临床数据可分析的患者中，有104位患者接受过PD-1/PD-L1抑制剂的治疗（单药或联合用药），93位患者的疗效可评估：疗效为CR、PR、SD、PD的患者的占比分别为4.3%、26.9%、22.6%、46.2%，临床受益率（CR+PR+SD）的占比为53.8%，其中，致病性/可能致病性POLE突变与PD-1/PD-L1抑制剂的临床获益显著相关（p=0.04)。"}, {"regimen_name": "PD-L1抑制剂", "tumor_name_cn": "实体瘤", "evidence_type": "Predictive", "refer_agency": "", "literature": "f2138d6c160d11edac9bc7f1c3325cc0,29352080,26619011,25228659,31829442", "clinical_significance": "Sensitive", "regimen_refer_agency": "", "evi_adaptation_disease_cn": null, "evi_adaptation_disease_en": null, "evidence_level": "Clinical-retrospective", "evi_conclusion": "C1", "evi_interpretation": "一项回顾性研究（DOI: 10.1200/JCO.2020.38.15_suppl.3008），分析了12947位病人的数据，有448位（3.5%）有POLE突变或者CNV，这些POLE突变中，致病性/可能致病性的占11.6%（34/293），良性/可能良性的占20.8%（61/293），意义不明确的占67.6%（198/293）。293个临床数据可分析的患者中，有104位患者接受过PD-1/PD-L1抑制剂的治疗（单药或联合用药），93位患者的疗效可评估：疗效为CR、PR、SD、PD的患者的占比分别为4.3%、26.9%、22.6%、46.2%，临床受益率（CR+PR+SD）的占比为53.8%，其中，致病性/可能致病性POLE突变与PD-1/PD-L1抑制剂的临床获益显著相关（p=0.04)。"}], "drug_var": {"drug_names": ["PD-1抑制剂", "PD-L1抑制剂"], "var": {"gene_symbol": "POLE", "gene_region": "exon9", "hgvs_p_abbr": "p.Pro286Arg", "hgvs_c": "c.857C>G", "hgvs_p": "p.P286R"}}, "gene_function": "POLE基因编码DNA聚合酶ε的催化亚基，具有聚合酶活性和核酸外切酶的校正活性。"}, {"sample_id": "BPTM-Lot19-Test01-Lib06-21031575F001D01", "order_code": "40ff693e1d6911ef8f8d0242ac170002", "bio_category": "Snvindel", "gene_symbol": "TP53", "transcript_primary": "NM_000546.6", "var_id": "75c281a9ad4c1aa28c17466cf1b5cd2d", "hgvs_c": "c.215C>G", "hgvs_p": "p.P72R", "hgvs_p_abbr": "p.Pro72Arg", "chr": "chr17", "start": "7579472", "end": "7579472", "ref": "G", "alt": "C", "gene_region": "exon4", "freq": 0.8608, "freq_case": 0.8608, "freq_ctrl": null, "freq_ss": null, "freq_sc": null, "freq_rc": null, "type": "nonSynonymous_Substitution", "tag": "PASS;Polymer;Polymorphism;WBC", "igvplot": null, "depth": 546.0, "json_batch_name": "20240425_XMHC_M019116_ADXHS-tBPTMplus_v1.0.1_20240507133628", "var_auto_result": null, "var_origin": "", "clinical_significance": "Benign", "function_classification": "-", "clinical_category": "Tier IV", "literature": "", "polymorphism": "Polymorphism", "variant_interpret_cn": "该变异在1000G、ExAC、gnomADe、gnomADg、iJGVD数据库人群等位基因频率分别为0.5429（2719/5008）、0.66（79805/120924）、0.6682（167398/250534）、0.6207（19434/31312）、0.6496（50303/77442）；FLOSSIES数据库报道有8372位60岁以上且没有确诊癌症的女性携带该变异；ClinVar数据库报道为Benign（ID=12351，可靠度为两颗星）。Cancer Hotspots数据库无记录。基于预测工具BayesDel及aGVGD认为该变异为neutral，剪接预测软件SpliceAI认为该变异不影响剪接。", "variant_interpret_en": "", "carcinogenicity_variant_interpret_cn": "该变异在1000G、ExAC、gnomADe、gnomADg、iJGVD数据库人群等位基因频率分别为0.5429（2719/5008）、0.66（79805/120924）、0.6682（167398/250534）、0.6207（19434/31312）、0.6496（50303/77442）；CKB数据库报道为unknown，COSMIC数据库记录268次TP53蛋白第72位氨基酸上的变异，其中突变型R记录227次。基于整合预测工具REVEL认为该变异为intermediate，剪接预测软件SpliceAI认为该变异不影响剪接。", "carcinogenicity_variant_interpret_en": "", "carcinogenicity_evidence_categorys": "SBVS1;OM3", "variant_desc_cn": "该变异为错义突变，导致基因编码蛋白第72位氨基酸由脯氨酸突变为精氨酸。", "variant_desc_en": "", "evidence_categorys": "BA1;BS2;BP4", "evi_sum": [], "drug_var": {"drug_names": [], "var": {"gene_symbol": "TP53", "gene_region": "exon4", "hgvs_p_abbr": "p.Pro72Arg", "hgvs_c": "c.215C>G", "hgvs_p": "p.P72R"}}, "gene_function": "TP53基因属于抑癌基因（PMID: 30562755），编码蛋白参与细胞周期停滞和凋亡，是肿瘤中最常发生突变的基因（PMID: 10065147, PMID: 22713868）。"}], "sv": [], "cnv": [], "cnv_file_path": [], "rna_sv": [], "mlpa": [], "hrd": [], "msi": [{"sample_id": "", "order_code": "40ff693e1d6911ef8f8d0242ac170002", "var_id": "MSS", "msi_score": 0.0, "img_path": "/var/www/html/report_backend/system_files/json_file/20240425_XMHC_M019116_ADXHS-tBPTMplus_v1.0.1_20240507133628/BPTM-Lot19-Test01-Lib06-21031575F001D01_BPTM-Lot19-Test01-Lib06-21031575F001D01_AHJV2FAFX5_1.msi.plot.png", "var_auto_result": "T", "variant_interpret_cn": "", "variant_interpret_en": "", "carcinogenicity_variant_interpret_cn": "", "carcinogenicity_variant_interpret_en": "", "variant_desc_cn": "微卫星（Microsatellite）又称简单重复序列（SSR），是指遍布于人类基因组中的短串联重复序列，一般由1-6个核苷酸组成。DNA复制时，肿瘤细胞内的微卫星由于重复单位的插入或缺失而造成的微卫星长度的变化，称为微卫星不稳定性（Microsatellite Instability, MSI）。大量研究表明，MSI是由错配修复（mismatch repair，MMR）基因突变或功能缺陷引起的（PMID: 25701956）。MSI在多种癌种中被发现，包括子宫内膜癌、结直肠癌和胃腺癌等。据报道，10%-15%的散发性结直肠癌患者存在MSI（PMID: 15528785），NCCN指南明确推荐所有结直肠癌患者均需考虑做MSI或MMR检测。临床上也已将MSI作为结直肠癌及其他实体瘤预后和制定辅助治疗方案的重要分子标志物。", "variant_desc_en": "", "evi_sum": [], "drug_var": {"drug_names": [], "var": {"biomarker_type": "MSS"}}}], "tmb": [], "pdl1": [], "knb": [], "ec_type": [{"sample_id": "", "order_code": "40ff693e1d6911ef8f8d0242ac170002", "var_id": "POLE-ultramutated type EC", "variant_interpret_cn": "", "variant_interpret_en": "", "carcinogenicity_variant_interpret_cn": "", "carcinogenicity_variant_interpret_en": "", "variant_desc_cn": "POLE突变型（POLE mut）子宫内膜癌的分子特征表现为体细胞突变多，体细胞拷贝数变异低，通常为微卫星稳定（MSS）；组织学特征表现常为高级别，常有明显的肿瘤浸润淋巴细胞；患者年龄相对较轻，具有正常的BMI（PMID: 34996131）。", "variant_desc_en": "", "evi_sum": [{"regimen_name": "", "tumor_name_cn": "子宫内膜癌", "evidence_type": "Prognostic", "refer_agency": "NCCN", "literature": "ee04796d160d11ed994ac7f1c3325cc0,34996131", "clinical_significance": "Better", "regimen_refer_agency": "", "evi_adaptation_disease_cn": null, "evi_adaptation_disease_en": null, "evidence_level": "Clinical-phase III", "evi_conclusion": "A2", "evi_interpretation": "在III期临床试验研究PORTEC-3中（PMID: 32749941），共入组410例子宫内膜癌患者并被随机分配接受辅助放化疗治疗（CTRT组）及单独放疗（RT组），通过免疫组化和DNA测序的方法将所有肿瘤样本分成四种分子分型，并对患者的总生存期（overall survival，OS）和无复发生存期（recurrence-free survival，RFS）进行统计分析。结果显示，POLE突变型（POLE mut）子宫内膜癌患者的5年无复发生存率为98%；辅助放化疗与辅助放疗相比，5年无复发生存率（100% vs 96.6%，P=0.637）和5年总生存率（100% vs 96.6%，P=0.637）差异无统计学意义。"}], "drug_var": {"drug_names": [], "var": {"biomarker_type": "POLE-ultramutated type EC"}}}], "cdx": [{"gene_symbol": "NTRK1", "tumor_group_id": "1", "tumor_name_cn": "实体瘤", "tumor_name_en": "Solid Tumor"}, {"gene_symbol": "NTRK2", "tumor_group_id": "1", "tumor_name_cn": "实体瘤", "tumor_name_en": "Solid Tumor"}, {"gene_symbol": "NTRK3", "tumor_group_id": "1", "tumor_name_cn": "实体瘤", "tumor_name_en": "Solid Tumor"}], "PGx": [{"clin_anno_cn": "与CT或TT基因型患者相比，C/C基因型的患者使用替加氟治疗时药物毒性较低", "clin_anno_en": null, "dbsnp": "rs3918290", "drug_name_cn": "替加氟", "drug_name_en": "tegafur", "evi_level": "1A", "gene_symbol": "DPYD", "genotype": "C/C", "impact_type_cn": "药物毒性较低", "impact_type_en": "Toxicity", "is_same_tumor": 0, "var_auto_result": null}, {"clin_anno_cn": "与AA基因型患者相比，G/G基因型的患者使用伊立替康治疗时药物毒性较低", "clin_anno_en": null, "dbsnp": "rs10929302", "drug_name_cn": "伊立替康", "drug_name_en": "irinotecan", "evi_level": "2A", "gene_symbol": "UGT1A1", "genotype": "G/G", "impact_type_cn": "药物毒性较低", "impact_type_en": "Toxicity", "is_same_tumor": 0, "var_auto_result": null}, {"clin_anno_cn": "与GG基因型患者相比，A/A基因型的患者使用蒽环类药物治疗时药物毒性较低", "clin_anno_en": null, "dbsnp": "rs7853758", "drug_name_cn": "蒽环类药物", "drug_name_en": "anthracyclines", "evi_level": "3", "gene_symbol": "SLC28A3", "genotype": "A/A", "impact_type_cn": "药物毒性较低", "impact_type_en": "Toxicity", "is_same_tumor": 0, "var_auto_result": null}, {"clin_anno_cn": "与AA基因型患者相比，C/C基因型的患者使用卡培他滨、氟尿嘧啶治疗时药物毒性较高", "clin_anno_en": null, "dbsnp": "rs55886062", "drug_name_cn": "氟尿嘧啶", "drug_name_en": "fluorouracil", "evi_level": "1A", "gene_symbol": "DPYD"