"lib_quality_control": {"lib_dna_qc": [{"sample_dna_id": "S22090311PD01", "library_id": "S22090311PD01L01", "dna_concn_q": "0.813", "dna_qty": "40.65", "dna_amount": "30", "library_concn": "116", "library_qty": "3480", "total_library_quality_control": "合格"}], "control_lib_dna_qc": [{"sample_dna_id": "S22090311WD01", "library_id": "S22090311WD01L01", "dna_concn_q": "126", "dna_qty": "12600", "dna_amount": "60", "-1": "150", "library_concn": "102", "library_qty": "3060", "total_library_quality_control": "合格"}], "rna_lib_qc": []}, "drug": [], "io_gene_clinical": [{"effect": "负相关", "evidence": "IFN信号通路相关基因在抗原呈递过程中发挥重要作用，IFN信号通路相关分子如 JAK1、JAK2、IFNGR1等基因突变也是免疫治疗原发或者获得性耐药的驱动基因（PMID:29070816;PMID:27667683;PMID:27433843）。在一项回顾性研究中（PMID: 27433843），研究人员对4名经PD-1(pembrolizumab)治疗数月至数年后出现疾病进展的黑色素瘤患者进行全外显子测序，结果显示有2名患者携带JAK1/2失活性突变，一名患者中发生B2M基因的阶段突变，这项研究认为：黑色素瘤患者对PD-1阻断免疫疗法的获得性耐药与干扰素受体信号传导和抗原呈递途径的缺陷有关。在另一项临床随访中（PMID:27903500），对23例接受抗PD-1治疗的晚期黑色素瘤患者的活检进行了全外显子组测序，在9例治疗无反应的患者中，1名患者鉴定出JAK1 P429S体细胞突变，2名患者携带IFNGR突变；分析了16例伴随错配修复缺陷的结肠癌患者活检组织进行全外显子测序数据，对PD-1治疗无反应的患者中，1名携带JAK1 W690 *无意义功能丧失突变，并伴随着JAK1位点杂合性的丧失，2名患者携带JAK1 / 2或B2M突变。这项研究认为：JAK1 / 2功能丧失突变可导致对PD-1的治疗产生耐药性，同时认为JAK1 / 2也可能参与了PD-1治疗的原发性耐药。", "gene_symbol": "JAK2", "test_significance": "IFN信号通路相关基因突变可能为免疫药物疗效的负向预测因子。", "tumor_name": null, "var_note": "激活性突变"}], "clinic_trial": [], "refer": [{"authors": "Kunihiro Yamaoka,Pipsa Saharinen,Marko Pesu,et al.", "date": "(2004)", "journal": "Genome Biol", "pmid": "[PMID:15575979]", "title": "The Janus kinases (Jaks).", "vol": "5(12):253."}, {"authors": "Grzegorz Helbig", "date": "(2018)", "journal": "Med Oncol", "pmid": "[PMID:30074114]", "title": "Classical Philadelphia-negative myeloproliferative neoplasms: focus on mutations and JAK2 inhibitors.", "vol": "35(9):119."}, {"authors": "Natsuki Kajikawa,Yoshimoto Seki,Takayuki Fujio,et al.", "date": "(2018)", "journal": "Intern Med", "pmid": "[PMID:29984752]", "title": "Central Nervous System Lymphoma Harboring the JAK2 V617F Mutation That D