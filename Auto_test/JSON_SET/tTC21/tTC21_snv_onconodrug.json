{"sample_info": {"order_id": "1-116-N20220860", "sample_parent_id": "1855540", "sample_id": "1-116-N20220860", "control_sample_id": null, "rna_sample_id": null, "patient_name": "甄志祥", "gender": "男", "age": "56", "sample_type": "石蜡标本", "control_sample_type": null, "sample_amount": null, "control_sample_amount": null, "tumor_type": "甲状腺癌", "pathol_diagn": "“右叶”甲状腺及纤维组织内分化差的癌浸润，建议做免组染色进一步确定组织类型", "tumor_names_cn": "甲状腺癌", "pathological_id": "B202239444A4", "company": "西安交通大学第一附属医院", "origin_company": null, "report_number": "N20220860", "hosp_depart": "耳鼻咽喉头颈外科", "prod_names": "TC21（组织）", "prod_ids": "13", "report_module_type": "hospital", "json_batch_name": "20221021_D4K9XF3_M000348_ADXPAN116_v0.2.0.export20221024165119", "mark": null, "tumor_content": null, "sample_position": null, "sample_position_id": null, "family_history": null, "gather_data": null, "receive_data": "2022-10-11", "report_data": "2022-10-24", "tumor_list": ["甲状腺癌", "未分化甲状腺癌", "甲状腺Hürthle细胞癌", "甲状腺玻璃样变性梁状腺瘤", "甲状腺髓样癌", "甲状腺嗜酸细胞腺瘤", "低分化甲状腺癌", "高分化甲状腺癌", "分化型甲状腺癌"]}, "snvindel": [{"sample_id": "1-116-N20220860", "order_code": "96095034537b11ed83790242ac170005", "bio_category": "Snvindel", "gene_symbol": "PTEN", "transcript_primary": "NM_000314.8", "var_id": "9ace84e59a9ae1ed66ec7a2e8bdeefb5", "hgvs_c": "c.492+3_492+6del", "hgvs_p": "p.?", "hgvs_p_abbr": "p.?", "chr": "chr10", "start": "89693011", "end": "89693014", "ref": "AAGT", "alt": "-", "gene_region": "intron5", "freq": 0.6379, "freq_case": null, "freq_ctrl": null, "freq_ss": 0.6437, "freq_sc": null, "type": "Intronic", "tag": "PASS", "igvplot": "/var/www/html/report_backend/system_files/json_file/20221021_D4K9XF3_M000348_ADXPAN116_v0.2.0.export20221024165119/1-116-N20220860_1-116-N20220860_AHWWFCAFX3_1/IGV/chr10_89693011_89693014.svg", "depth": 1831.0, "json_batch_name": "20221021_D4K9XF3_M000348_ADXPAN116_v0.2.0.export20221024165119", "var_origin": "", "clinical_significance": "Uncertain", "function_classification": "Uncertain", "clinical_category": "Tier III", "literature": "", "polymorphism": "Non-Polymorphism", "variant_interpret_cn": "该变异在1000G、ExAC、gnomAD数据库无记录；在ClinVar数据库无记录。基于剪接预测软件SpliceAI认为该变异影响剪接。", "variant_interpret_en": "", "variant_desc_cn": "该变异为内含子区突变。", "variant_desc_en": "", "evidence_categorys": "PM2;PP3", "evi_sum": [], "drug_var": {"drug_names": [], "var": {"gene_symbol": "PTEN", "gene_region": "intron5", "hgvs_p_abbr": "p.?", "hgvs_c": "c.492+3_492+6del", "hgvs_p": "p.?"}}, "gene_function": "PTEN基因属于抑癌基因，在PI3K/AKT/mTOR信号通路中起着负调控作用，因此PTEN突变失活可能导致该信号通路异常激活，从而促进肿瘤的发生与发展。PTEN基因突变在多种肿瘤中均有发生，如乳腺癌、结直肠癌，甲状腺癌等，在结直肠癌中的发生概率约为5-14%，大部分属于功能失活突变（PMID: 21103049, PMID: 21163703）。"}, {"sample_id": "1-116-N20220860", "order_code": "96095034537b11ed83790242ac170005", "bio_category": "Snvindel", "gene_symbol": "TSHR", "transcript_primary": "NM_000369.3", "var_id": "8868e2dd10f3987f7b81f9d50dbd3d1b", "hgvs_c": "c.1377G>T", "hgvs_p": "p.(A459=)", "hgvs_p_abbr": "p.(Ala459=)", "chr": "chr14", "start": "81609779", "end": "81609779", "ref": "G", "alt": "T", "gene_region": "exon10", "freq": 0.8323, "freq_case": null, "freq_ctrl": null, "freq_ss": 0.8254, "freq_sc": null, "type": "Synonymous_Substitution", "tag": "PASS;PW;WBC", "igvplot": "/var/www/html/report_backend/system_files/json_file/20221021_D4K9XF3_M000348_ADXPAN116_v0.2.0.export20221024165119/1-116-N20220860_1-116-N20220860_AHWWFCAFX3_1/IGV/chr14_81609779_81609779.svg", "depth": 5789.0, "json_batch_name": "20221021_D4K9XF3_M000348_ADXPAN116_v0.2.0.export20221024165119", "var_origin": "", "clinical_significance": "Uncertain", "function_classification": "Uncertain", "clinical_category": "Tier III", "literature": "", "polymorphism": "Non-Polymorphism", "variant_interpret_cn": "ClinVar数据库无记录，其与肿瘤发生发展的相关性暂不明确。", "variant_interpret_en": "", "variant_desc_cn": "该变异为同义突变。", "variant_desc_en": "", "evidence_categorys": "", "evi_sum": [], "drug_var": {"drug_names": [], "var": {"gene_symbol": "TSHR", "gene_region": "exon10", "hgvs_p_abbr": "p.(Ala459=)", "hgvs_c": "c.1377G>T", "hgvs_p": "p.(A459=)"}}, "gene_function": "TSHR（甲状腺刺激激素受体）是一种蛋白质编码基因。其相关途径包括通过GPCR发出信号和甲状腺素（甲状腺激素）的产生。 TSHR是促甲状腺素的受体，促甲状腺素的作用是促进甲状腺细胞的增殖和功能（PMID：21511239； PMID：25333622）。 在甲状腺癌中经常观察到TSHR突变（PMID：21511239; PMID：25333622），在肝细胞癌中也观察到了TSHR突变（PMID：29715101）。"}, {"sample_id": "1-116-N20220860", "order_code": "96095034537b11ed83790242ac170005", "bio_category": "Snvindel", "gene_symbol": "GNAS", "transcript_primary": "NM_000516.6", "var_id": "041f97e5fe2b505a533e4b636b9fa5e4", "hgvs_c": "c.601C>T", "hgvs_p": "p.R201C", "hgvs_p_abbr": "p.Arg201Cys", "chr": "chr20", "start": "57484420", "end": "57484420", "ref": "C", "alt": "T", "gene_region": "exon8", "freq": 0.6619, "freq_case": null, "freq_ctrl": null, "freq_ss": 0.6441, "freq_sc": null, "type": "nonSynonymous_Substitution", "tag": "PASS;HotSpot;PW", "igvplot": "/var/www/html/report_backend/system_files/json_file/20221021_D4K9XF3_M000348_ADXPAN116_v0.2.0.export20221024165119/1-116-N20220860_1-116-N20220860_AHWWFCAFX3_1/IGV/chr20_57484420_57484420.svg", "depth": 3978.0, "json_batch_name": "20221021_D4K9XF3_M000348_ADXPAN116_v0.2.0.export20221024165119", "var_origin": "", "clinical_significance": "Likely pathogenic", "function_classification": "Oncogenic", "clinical_category": "Tier III", "literature": "20531296,24498230", "polymorphism": "Non-Polymorphism", "variant_interpret_cn": "根据JAX CKB数据库记录，该突变可导致Gnas的GTP酶活性丢失，从而导致下游信号持续激活、细胞增殖及肿瘤形成（PMID: 20531296, PMID: 24498230）。ClinVar数据库记录该突变为Pathogenic/Likely pathogenic​（ClinVarID=15933），OncoKB数据库记录该突变为Oncogenic。", "variant_interpret_en": "", "variant_desc_cn": "该变异为错义突变，导致基因编码蛋白第201位氨基酸由精氨酸突变为半胱氨酸。", "variant_desc_en": "", "evidence_categorys": "", "evi_sum": [], "drug_var": {"drug_names": [], "var": {"gene_symbol": "GNAS", "gene_region": "exon8", "hgvs_p_abbr": "p.Arg201Cys", "hgvs_c": "c.601C>T", "hgvs_p": "p.R201C"}}, "gene_function": "GNAS基因属于原癌基因，作为一个重要的信号转导蛋白，主要功能是在G蛋白偶联受体信号转导途径中，激活腺苷酸环化酶，导致cAMP水平的升高，参与调控细胞生长和细胞分裂。GNAS基因的点突变，其中许多涉及R201和Q227残基，可导致本构性信号活性，导致细胞增殖和肿瘤发生(PMID: 23640210)。GNAS基因突变在多种肿瘤中均有发生，包括结肠癌、甲状旁腺癌、卵巢癌、肝细胞癌和胰腺导管内乳头状黏液性肿瘤(PMID: 23640210)。"}], "sv": [], "cnv": [], "cnv_file_path": {"sample_id": "1-116-N20220860", "abs_path": "/var/www/html/report_backend/system_files/json_file/20221021_D4K9XF3_M000348_ADXPAN116_v0.2.0.export20221024165119/1-116-N20220860_1-116-N20220860_AHWWFCAFX3_1/1-116-N20220860_1-116-N20220860_AHWWFCAFX3_1_TC21.cnv.png"}, "rna_sv": [], "mlpa": [], "hrd": [], "msi": [{"sample_id": "", "order_code": "96095034537b11ed83790242ac170005", "var_id": "MSS", "msi_score": 0.0385, "img_path": "/var/www/html/report_backend/system_files/json_file/20221021_D4K9XF3_M000348_ADXPAN116_v0.2.0.export20221024165119/1-116-N20220860_1-116-N20220860_AHWWFCAFX3_1/1-116-N20220860_1-116-N20220860_AHWWFCAFX3_1.msi.png", "variant_interpret_cn": "", "variant_interpret_en": "", "variant_desc_cn": "微卫星（Microsatellite）又称简单重复序列（SSR），是指遍布于人类基因组中的短串联重复序列，一般由1-6个核苷酸组成。DNA复制时，肿瘤细胞内的微卫星由于重复单位的插入或缺失而造成的微卫星长度的变化，称为微卫星不稳定性（Microsatellite Instability, MSI）。大量研究表明，MSI是由错配修复（mismatch repair，MMR）基因突变或功能缺陷引起的（PMID: 25701956）。MSI在多种癌种中被发现，包括子宫内膜癌、结直肠癌和胃腺癌等。据报道，10%-15%的散发性结直肠癌患者存在MSI（PMID: 15528785），NCCN指南明确推荐所有结直肠癌患者均需考虑做MSI或MMR检测。临床上也已将MSI作为结直肠癌及其他实体瘤预后和制定辅助治疗方案的重要分子标志物。", "variant_desc_en": "", "evi_sum": [], "drug_var": {"drug_names": [], "var": {"biomarker_type": "MSS"}}}], "tmb": [], "pdl1": [], "knb": [], "ec_type": [], "cdx": [{"gene_symbol": "BRAF", "tumor_group_id": "1", "tumor_name_cn": "甲状腺癌", "tumor_name_en": "Thyroid Cancer"}, {"gene_symbol": "RET", "tumor_group_id": "1", "tumor_name_cn": "甲状腺癌", "tumor_name_en": "Thyroid Cancer"}], "PGx": [{"clin_anno_cn": "与AA基因型患者相比，G/G基因型的患者使用吉西他滨治疗时药物毒性较低", "clin_anno_en": null, "dbsnp": "rs60369023", "drug_name_cn": "吉西他滨", "drug_name_en": "gemcitabine", "evi_level": "3", "gene_symbol": "CDA", "genotype": "G/G", "impact_type_cn": "药物毒性较低", "impact_type_en": "Toxicity", "is_same_tumor": 0}, {"clin_anno_cn": "与GG基因型患者相比，A/A基因型的患者使用铂类治疗时疗效较差（但也有报道认为该基因型与生存期无关）", "clin_anno_en": null,