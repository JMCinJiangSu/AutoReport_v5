    "io_gene_clinical": [
        {
            "effect": "正相关",
            "evidence": "一项临床研究中，分析了521名接受免疫治疗的患者，其中携带TERT基因突变患者的中位生存期24个月，而无突变患者只有17个月。在非小细胞肺癌患者中，TERT突变的患者有效率更高（35.4%vs 17.4%）、中位无疾病进展生存时间更长（8.8个月vs 3.1个月）(PMID:32241817)。",
            "gene_symbol": "TERT",
            "test_significance": "TERT突变可能为免疫药物疗效正向预测因子。",
            "tumor_name": "非小细胞肺癌",
            "var_note": "突变"
        }
