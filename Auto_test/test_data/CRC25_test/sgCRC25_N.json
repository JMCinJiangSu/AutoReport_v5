    "drug": [
        {
            "general_name_cn": "帕尼单抗",
            "var": [
                {
                    "biomarker_type": "KRAS/NRAS/BRAF WT"
                }
            ],
            "general_name_en": "Panitumumab",
            "trade_name_cn": "维克替比",
            "trade_name_en": "Vectibix",
            "approval_organization": [
                "FDA",
                "PMDA"
            ],
            "drug_mechanism_cn": "Panitumumab与正常和肿瘤细胞上的EGFR特异性结合，并竞争性抑制EGFR配体的结合。 非临床研究表明，Panitumumab与EGFR结合可阻止配体诱导的受体自磷酸化和受体相关激酶的激活，从而抑制细胞生长，诱导凋亡，减少促炎细胞因子和血管生长因子的产生以及EGFR的内化。 体外测定和体内动物研究表明，Panitumumab可以抑制表达EGFR的某些人类肿瘤细胞系的生长和存活。",
            "adaptation_disease_cn": null
        },
        {
            "general_name_cn": "西妥昔单抗",
            "var": [
                {
                    "biomarker_type": "KRAS/NRAS/BRAF WT"
                }
            ],
            "general_name_en": "Cetuximab",
            "trade_name_cn": "爱必妥",
            "trade_name_en": "Erbitux",
            "approval_organization": [
                "FDA",
                "NMPA",
                "PMDA"
            ],
            "drug_mechanism_cn": "表皮生长因子受体（EGFR，HER1，c-ErbB-1）是跨膜糖蛋白，是I型受体酪氨酸激酶（包括EGFR，HER2，HER3和HER4）亚族成员之一。 EGFR在包括皮肤和毛囊在内的许多正常上皮组织中组成性表达。EGFR的表达在多种人类癌症（包括头颈部癌、结肠和直肠癌）中同样被检出。西妥昔单抗与正常和肿瘤细胞上的EGFR特异性结合，并竞争性抑制表皮生长因子（EGF）和其他配体（如转化生长因子-α）的结合。体外试验和体内动物研究表明，西妥昔单抗与EGFR的结合可阻断受体相关激酶的磷酸化和激活，从而抑制细胞生长，诱导细胞凋亡，并降低基质金属蛋白酶和血管内皮生长因子的产生。EGFR信号转导可导致野生型Ras蛋白的激活，但是在具有激活性Ras体细胞突变的细胞中，突变Ras蛋白都表现出持续的活性，不受EGFR调控状态的影响。在体外，西妥昔单抗可调节针对部分类型人类肿瘤的抗体依赖性细胞毒性（ADCC）。体外试验和体内动物研究表明，西妥昔单抗可抑制EGFR表达肿瘤细胞的生长和存活。在缺乏EGFR表达的人源肿瘤异种移植体中未观察到西妥昔单抗的抗肿瘤作用。在人源肿瘤异种移植小鼠模型中，西妥昔单抗加放疗或西妥昔单抗加伊立替康的抗肿瘤效果强于单独的放疗或化疗。",
            "adaptation_disease_cn": null
        }
    ],
